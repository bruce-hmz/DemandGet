# Database Configuration
DATABASE_URL=postgresql+asyncpg://chuhai_user:chuhai_pass@postgres:5432/chuhai

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Pricing (per 1K tokens)
LLM_PRICE_IN=0.0015
LLM_PRICE_OUT=0.002
LLM_MONTHLY_BUDGET=100.0

# API Keys for External Services
OPENAI_API_KEY=your-openai-api-key
SENSENOVA_API_KEY=your-sensenova-api-key
GLM_API_KEY=your-glm-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
STACKEX_API_KEY=your-stackexchange-api-key

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Logging
LOG_LEVEL=info

# Celery Worker Configuration
WORKER_CONCURRENCY=2

# pgAdmin (optional)
PGADMIN_DEFAULT_EMAIL=pgadmin4@chuhai.com
PGADMIN_DEFAULT_PASSWORD=admin
