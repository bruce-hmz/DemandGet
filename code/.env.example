# 复制为 .env 后填写真实值
# 三家 LLM provider 三选一，按 config.yaml 里 llm.provider 决定用哪个

# ---------- 国产 LLM (推荐, 便宜 + 不要 VPN) ----------
# SenseNova 商汤日日新 (申请: https://platform.sensenova.cn/)
SENSENOVA_API_KEY=

# GLM 智谱清言 (申请: https://open.bigmodel.cn/)
GLM_API_KEY=

# ---------- 海外 LLM (可选) ----------
# Anthropic Claude (申请: https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# ---------- 搜索 / 数据源 ----------
# DuckDuckGo: 完全免费，无需 key
# HackerNews: 完全免费，无需 key
# Stack Exchange: 免费 300/天，无需 key

# 可选: Stack Exchange API key (https://stackapps.com/apps/oauth/register)
# 免费但能把配额从 300/天 升到 10000/天
STACKEX_API_KEY=

# 可选: Brave Search 已废弃（免费层需信用卡），现用 DuckDuckGo 替代
# BRAVE_API_KEY=

# 可选: firecrawl (G2/Capterra/Upwork 抓取，付费 $16/月起)
# 等 v0.3 加 G2 通道时再申请
FIRECRAWL_API_KEY=
